{
  "name": "reasoning-across-borders",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "node --experimental-strip-types --test tests/rendered-html.test.mjs tests/release-config.test.mjs tests/answer-leaks.test.mjs tests/scoring.test.ts tests/scoring-config.test.ts tests/submission.test.ts tests/submissions-route.test.ts tests/anti-abuse.test.ts tests/benchmark-session.test.ts tests/embed.test.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern outputs --ignore-pattern work",
    "db:generate": "drizzle-kit generate",
    "scoring:seed": "node scripts/generate-scoring-seed.mjs",
    "scoring:test-private": "node --experimental-strip-types scripts/run-private-scoring-cases.mjs",
    "scoring:verify-no-leaks": "node scripts/verify-answer-leaks.mjs",
    "release:verify-config": "node scripts/verify-release-config.mjs"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-loading-skeleton": "3.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
